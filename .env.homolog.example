VITE_APP_ENV="homolog"
VITE_APP_ENV_LABEL="Homologacao"
VITE_APP_WRITE_GUARD="readonly"
VITE_ALLOW_REAL_WRITES="false"
VITE_SANDBOX_PUBLIC_URL="https://sandbox.bibliotecai.com.br/sandbox"

# Preencha com endpoints e chaves do ambiente de homologacao.
# Mesmo se alguem copiar endpoints de producao por engano, as mutacoes
# seguem bloqueadas ate VITE_ALLOW_REAL_WRITES=true.
VITE_SUPABASE_PROJECT_ID="preencher-projeto-homolog"
VITE_SUPABASE_PUBLISHABLE_KEY="preencher-chave-publica-homolog"
VITE_SUPABASE_URL="https://preencher-homolog.supabase.co"
VITE_PLATFORM_API_BASE_URL="https://preencher-api-homolog.exemplo.dev"
VITE_APP_BASE_DOMAIN="homolog.bibliotecai.local"
VITE_ENABLE_OPTIONAL_STUDENT_FEATURES="true"
VITE_ENABLE_MATRICULA_RPC="true"
